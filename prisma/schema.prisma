generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model RecurringSchedule {
  id          Int       @id @default(autoincrement())
  dayOfWeek   Int       // 0=일요일 ~ 6=토요일
  startTime   String    // "10:00"
  endTime     String    // "12:00"
  location    String
  maxCapacity Int
  description String?
  isActive    Boolean   @default(true)
  meetings    Meeting[]
  createdAt   DateTime  @default(now())
}

model Meeting {
  id           Int                @id @default(autoincrement())
  scheduleId   Int?
  schedule     RecurringSchedule? @relation(fields: [scheduleId], references: [id])
  date         String             // "2026-03-21"
  startTime    String             // "10:00"
  endTime      String             // "12:00"
  location     String
  maxCapacity  Int
  description  String?
  isOpen       Boolean            @default(true)
  isOverridden Boolean            @default(false)
  participants Participant[]
  createdAt    DateTime           @default(now())
}

model Participant {
  id               Int       @id @default(autoincrement())
  meetingId        Int
  meeting          Meeting   @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  name             String
  kakaoId          String
  user             User?     @relation(fields: [kakaoId], references: [kakaoId])
  kakaoNickname    String    // 카카오 프로필 닉네임 (참고용)
  note             String?
  status           String    @default("PENDING") // PENDING | APPROVED | WAITLISTED | REJECTED
  waitlistPosition Int?
  rejectionNote    String?
  submittedAt      DateTime  @default(now())
  reviewedAt       DateTime?

  @@unique([meetingId, kakaoId])
}

model Notice {
  id        Int      @id @default(autoincrement())
  title     String
  body      String
  isPinned  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Marathon {
  id          Int      @id @default(autoincrement())
  title       String
  date        String   // YYYY-MM-DD
  startTime   String   // HH:MM
  location    String?
  description String?
  link        String?  // 접수 링크
  createdAt   DateTime @default(now())
  
  // 카카오 연동 시 작성자 추적용
  createdById String?

  participants MarathonParticipant[]
}

model MarathonParticipant {
  id          Int      @id @default(autoincrement())
  marathonId  Int
  marathon    Marathon @relation(fields: [marathonId], references: [id], onDelete: Cascade)
  kakaoId     String
  user        User?    @relation(fields: [kakaoId], references: [kakaoId])
  name        String
  note        String?
  status      String   @default("APPROVED")
  submittedAt DateTime @default(now())

  @@unique([marathonId, kakaoId])
}

model User {
  id           Int      @id @default(autoincrement())
  kakaoId      String   @unique
  name         String?  // 카카오 또는 유저가 정한 이름
  profileImage String?
  phoneNumber  String?
  role         String   @default("MEMBER") // ADMIN, MEMBER, BANNED
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  participants         Participant[]
  marathonParticipants MarathonParticipant[]
}
